# ===========================================
# AUTHENTICATION (Choose ONE option)
# ===========================================

# Option 1: Anthropic API (Recommended for personal use)
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# Option 2: Amazon Bedrock (For AWS users)
# Uncomment and configure if using Bedrock
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1

# Option 3: Google Vertex AI
# Uncomment and configure if using Vertex
# CLAUDE_CODE_USE_VERTEX=1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# ANTHROPIC_VERTEX_PROJECT_ID=your_project_id
# CLOUD_ML_REGION=us-east5

# ===========================================
# MODEL CONFIGURATION (Optional)
# ===========================================

# Override default model (optional)
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250514

# ===========================================
# API CONFIGURATION (Required)
# ===========================================

# Mutual Funds API endpoint
API_BASE_URL=https://upstocks-api.onrender.com
